<div class="presearch-component">
<script type="text/javascript">
var NeoSearch = NeoSearch || {};
NeoSearch.presearchUrl = '/apl/prebuscador/index_es.html';
/* Assumes a 'data' variable with the JSON content and loaded JQuery. */
const productsType = 'ProductosServicios';
const oficinasType = 'Oficinas';
const faqsType = 'Faqs';
const videosType = 'Videos';
const maybeType = 'Oficinas2';
const sugestionType = 'Sugerencias';
var parseProducts = function(obj){
jQuery.each(obj.items, function(idx, product){
product.idx = idx;
if (idx > 0 && product.video){
product.video = null;
}
});
return obj;
};
var parseOficinas = function(obj){
if (window.CookiePolicy && NeoCookiePolicy.isCookiePolicyActive()){
if(CookiePolicy.isAllowedComponent('google_publicidad')) {
return obj;
}
}
else {
return obj;
}
};
var parseMaybe = function(obj){ return obj;};
var parseFaqs = function(obj){ return obj;};
var parseVideos = function(obj){
jQuery.each(obj.items, function(idx, video){
video.idx = idx;
if (idx > 0 && video.data){
video.data = null;
}
});
return obj;
};
function processJson (data){
jQuery.each(data.searchgroups, function(idx, obj){
switch(obj.type){
case sugestionType:{
data.sugerencias = parseProducts(obj);
break;
}
case productsType:{
data.products = parseProducts(obj);
break;
}
case oficinasType:{
data.oficinas = parseOficinas(obj);
break;
}
case faqsType:{
data.faqs = parseFaqs(obj);
break;
}
case videosType:{
data.videos = parseVideos(obj);
break;
}
case maybeType:{
data.maybe = parseMaybe(obj);
break;
}
}
});
}
const NeoSearchOrder= [];
NeoSearchOrder.push('sugerencias');
NeoSearchOrder.push('products');
NeoSearchOrder.push('widgetAutoFetchLink');
NeoSearchOrder.push('widgetBlocks');
NeoSearchOrder.push('faqs');
NeoSearchOrder.push('oficinas');
NeoSearchOrder.push('maybe');
NeoSearchOrder.push('videos_PENDING');
NeoSearch.processPresearchJson = function(data){
processJson(data);
return data;
}
</script>
